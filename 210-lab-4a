#include <iostream>
#include <vector>
#include <cstdlib> // for rand and srand
#include <ctime>   // for time

using namespace std;

// Define the Color struct
struct Color
{
    int red;
    int green;
    int blue;
};

int main()
{
    srand(time(0));

    vector<Color> colors;

    int n = rand() % 26 + 25;

    for (int i = 0; i < n; i++)
    {
        Color temp;
        temp.red = rand() % 256; // Values from 0 to 255
        temp.green = rand() % 256;
        temp.blue = rand() % 256;

        colors.push_back(temp);
    }

    cout << "\nList of " << n << " random colors:\n";
    cout << "Color#\tR\tG\tB\n";
    cout << "-----------------------------\n";

    for (int i = 0; i < colors.size(); i++)
    {
        cout << i << "\t"
        << colors[i].red << "\t"
        << colors[i].green << "\t"
        << colors[i].blue << endl;
    }

    return 0;
}
